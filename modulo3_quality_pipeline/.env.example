# Módulo 3 — QualityAI — Variables de entorno
# Copia este archivo como .env y completa los valores

# ── Selector de proveedor LLM ─────────────────────────────────────────────────
# Opciones: gemini | groq | deepseek
LLM_PROVIDER=gemini

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=tu_clave_gemini_aqui
GEMINI_GENERATION_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# ── Groq ──────────────────────────────────────────────────────────────────────
# Obtén tu key en: console.groq.com
GROQ_API_KEY=tu_clave_groq_aqui
GROQ_MODEL=llama-3.3-70b-versatile
# Modelos alternativos Groq:
# GROQ_MODEL=llama-3.1-70b-versatile
# GROQ_MODEL=mixtral-8x7b-32768

# ── DeepSeek ──────────────────────────────────────────────────────────────────
# Obtén tu key en: platform.deepseek.com
DEEPSEEK_API_KEY=tu_clave_deepseek_aqui
DEEPSEEK_MODEL=deepseek-chat
# Modelo alternativo (con razonamiento chain-of-thought):
# DEEPSEEK_MODEL=deepseek-reasoner

# ── RAG (los embeddings siempre usan Gemini — no hay alternativa local equivalente)
CHROMA_PERSIST_DIR=./chroma_db_m3
STORIES_COLLECTION_NAME=m3_stories_chunked
PATTERNS_COLLECTION_NAME=m3_patterns_chunked

RAG_BM25_TOP_K=20
RAG_DENSE_TOP_K=20
RAG_RRF_K=60
RAG_RERANKER_TOP_N=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Pipeline ──────────────────────────────────────────────────────────────────
GENERATION_TEMPERATURE=0.3
MAX_RETRIES=3
