# Módulo 3 — QualityAI — Variables de entorno
# Copia este archivo como .env y completa los valores

# ── Selector de proveedor LLM ─────────────────────────────────────────────────
# Opciones: gemini | groq | deepseek
LLM_PROVIDER=gemini

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=tu_clave_gemini_aqui
GEMINI_GENERATION_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# ── Groq ──────────────────────────────────────────────────────────────────────
# Obtén tu key en: console.groq.com
GROQ_API_KEY=tu_clave_groq_aqui
GROQ_MODEL=llama-3.3-70b-versatile
# Modelos alternativos Groq:
# GROQ_MODEL=llama-3.1-70b-versatile
# GROQ_MODEL=mixtral-8x7b-32768

# ── DeepSeek ──────────────────────────────────────────────────────────────────
# Obtén tu key en: platform.deepseek.com
DEEPSEEK_API_KEY=tu_clave_deepseek_aqui
DEEPSEEK_MODEL=deepseek-chat
# Modelo alternativo (con razonamiento chain-of-thought):
# DEEPSEEK_MODEL=deepseek-reasoner

# ── RAG (los embeddings siempre usan Gemini — no hay alternativa local equivalente)
CHROMA_PERSIST_DIR=./chroma_db_m3
STORIES_COLLECTION_NAME=m3_stories_chunked
PATTERNS_COLLECTION_NAME=m3_patterns_chunked

RAG_BM25_TOP_K=20
RAG_DENSE_TOP_K=20
RAG_RRF_K=60
RAG_RERANKER_TOP_N=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Pipeline ──────────────────────────────────────────────────────────────────
GENERATION_TEMPERATURE=0.3
MAX_RETRIES=3

# ── MongoDB ───────────────────────────────────────────────────────────────────
# En Docker: usar el nombre del servicio "mongodb"
# En local sin Docker: usar "localhost"
MONGODB_URL=mongodb://admin:changeme@mongodb:27017/qualityai?authSource=admin
MONGO_DB_NAME=qualityai
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme

# ── Usuario admin por defecto (se crea al arrancar si no existe) ──────────────
ADMIN_EMAIL=admin@qualityai.com
ADMIN_PASSWORD=admin1234

# ── JWT ───────────────────────────────────────────────────────────────────────
# Cambiar por un secreto seguro en producción (mínimo 32 caracteres)
JWT_SECRET=cambia_esto_por_un_secreto_seguro_en_produccion
JWT_EXPIRE_MINUTES=480

# ── Jira ─────────────────────────────────────────────────────────────────────
# URL de tu instancia Jira (Cloud: https://tu-empresa.atlassian.net)
JIRA_URL=https://tu-empresa.atlassian.net
# Email de la cuenta de servicio con permisos en el proyecto
JIRA_EMAIL=tu-email@empresa.com
# API token generado en: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=tu_api_token_jira
# Clave del proyecto Jira donde se crearán los tickets (ej: PROJ, QA, DEV)
JIRA_PROJECT_KEY=PROJ
# Nombres de los tipos de issue (pueden variar según tu configuración de Jira)
JIRA_EPIC_TYPE=Epic
JIRA_STORY_TYPE=Story
JIRA_SUBTASK_TYPE=Sub-task
# Campo custom del nombre del Epic (Jira Cloud: customfield_10011)
JIRA_EPIC_NAME_FIELD=customfield_10011
# Campo custom del link al Epic en Stories (Jira Cloud: customfield_10014)
JIRA_EPIC_LINK_FIELD=customfield_10014
