# El backend lee el .env de modulo3_quality_pipeline directamente.
# Asegúrate de tener ../modulo3_quality_pipeline/.env configurado con:
#
# LLM_PROVIDER=gemini          # gemini | groq | deepseek
# GEMINI_API_KEY=...
# GROQ_API_KEY=...
# DEEPSEEK_API_KEY=...
#
# Ver modulo3_quality_pipeline/.env.example para la lista completa.
